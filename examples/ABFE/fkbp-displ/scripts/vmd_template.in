menu graphics on

mol modselect 0 0 chain A and protein and noh
mol color Name
mol representation Lines 1.000000
mol selection chain B and protein and noh
mol material Opaque

mol addrep 0
mol modselect 1 0 resname L1 and noh
mol modstyle 1 0 Licorice 0.300000 12.000000 12.000000

mol addrep 0
mol modselect 2 0 resname L2 and noh
mol modstyle 2 0 Licorice 0.300000 12.000000 12.000000
mol modcolor 2 0 Type
color Type C green

#pbc wrap -center com -centersel "index <LIG1ATTACHATOM> " -compound fragment -all

for {set i 0} {$i < [molinfo top get numframes]} {incr i} {
  set selB [atomselect top "index <LIG1ATTACHATOM> " frame $i]
  set selC [atomselect top "index <LIG2ATTACHATOM> " frame $i]
  set coordB [lindex [$selB get {x y z}] 0]
  set coordC [lindex [$selC get {x y z}] 0]
  set offset [vecsub $coordB $coordC]
  set sel [atomselect top "resname L2" frame $i ]
  $sel moveby $offset
}
